// snakecasename/src/components/Loading.js

import React from 'react';

const Loading = () => {
  return (
    <div className="loading">
      <img src="/images/loading.gif" alt="" />
    </div>
  );
};

export default Loading;

This component will display a loading spinner while the app is in progress.
// snakecasename/src/components/Empty.js

import React from 'react';

const Empty = () => {
  return (
    <div className="empty">
      <h1>No content</h1>
    </div>
  );
};

export default Empty;

This component will display a message indicating that there is no data available.
// snakecasename/src/components/Error.js

import React from 'react';

const Error = ({ error }) => {
  return (
    <div className="error">
      {error.message}
    </div>
  );
};

export default Error;

This component will display the specific error message that occurred.
